# ==============================================================
# NombaRecur — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env.
# ==============================================================

# --- App ---
APP_ENV=sandbox          # sandbox | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
DATABASE_URL=sqlite:///./nombarecur.db

# --- Nomba Credentials ---
# NOMBA_ACCOUNT_ID   = the PARENT account ID (goes in `accountId` header on every API call)
# NOMBA_CLIENT_ID    = your sub-account's Client ID
# NOMBA_CLIENT_SECRET = your sub-account's Private Key
NOMBA_ACCOUNT_ID=your-parent-account-id
NOMBA_CLIENT_ID=your-sub-account-client-id
NOMBA_CLIENT_SECRET=your-sub-account-private-key
NOMBA_WEBHOOK_SECRET=your-nomba-webhook-secret

# --- Nomba API URLs (sandbox) ---
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_AUTH_URL=https://sandbox.nomba.com/v1/auth/token/issue

# --- Nomba API URLs (production — swap when going live) ---
# NOMBA_BASE_URL=https://api.nomba.com
# NOMBA_AUTH_URL=https://api.nomba.com/v1/auth/token/issue

# --- Encryption (for storing tenant credentials at rest) ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# --- Email (Sendbyte) ---
SENDBYTE_API_KEY=your-sendbyte-api-key
